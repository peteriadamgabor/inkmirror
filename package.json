    "idb": "^8.0.3",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.8.0",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260416.2",
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.0",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.4.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "puppeteer-core": "^24.40.0",
