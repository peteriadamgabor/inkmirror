# vite-plugin-pwa@1.2.0 declares peer vite <=7 but runs fine on vite 8
# (latest). Until a new vite-plugin-pwa ships that widens the peer,
# keep installs passing. Revisit when an upstream release lands.
legacy-peer-deps=true

# Pin exact versions — package.json reads as the shipped state, and
# future `npm install <pkg>` won't silently add a ^ range.
save-exact=true
